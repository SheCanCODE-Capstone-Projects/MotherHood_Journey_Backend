<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
        "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
        "https://checkstyle.org/dtds/configuration_1_3.dtd">

<module name="Checker">

    <property name="severity" value="error"/>
    <property name="fileExtensions" value="java"/>

    <!-- Skip generated MapStruct files -->
    <module name="BeforeExecutionExclusionFileFilter">
        <property name="fileNamePattern"
                  value=".*[\\/]generated-sources[\\/].*"/>
    </module>

    <module name="TreeWalker">

        <!-- No line longer than 120 characters -->
        <module name="LineLength">
            <property name="max" value="120"/>
            <property name="ignorePattern"
                      value="^package.*|^import.*|a href|href|http://|https://|ftp://"/>
        </module>

        <!-- No unused imports -->
        <module name="UnusedImports"/>

        <!-- No duplicate imports -->
        <module name="RedundantImport"/>

        <!-- No star imports like import java.util.* -->
        <module name="AvoidStarImport"/>

        <!-- Proper indentation — 4 spaces -->
        <module name="Indentation">
            <property name="basicOffset" value="4"/>
            <property name="caseIndent" value="4"/>
        </module>

        <!-- Braces required for if, else, for, while -->
        <module name="NeedBraces"/>

        <!-- Opening brace on same line -->
        <module name="LeftCurly"/>

        <!-- Closing brace on its own line -->
        <module name="RightCurly"/>

        <!-- No whitespace before semicolons or commas -->
        <module name="NoWhitespaceBefore"/>

        <!-- Whitespace after commas and semicolons -->
        <module name="WhitespaceAfter"/>

        <!-- No multiple blank lines in a row -->
        <module name="EmptyLineSeparator">
            <property name="allowNoEmptyLineBetweenFields" value="true"/>
        </module>

        <!-- Each class in its own file -->
        <module name="OneTopLevelClass"/>

        <!-- No trailing whitespace -->
        <module name="Regexp">
            <property name="format" value="[ \t]+$"/>
            <property name="illegalPattern" value="true"/>
            <property name="message" value="Trailing whitespace"/>
        </module>

    </module>

</module>